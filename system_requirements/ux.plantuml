rectangle "SCR-22\nПереход к партнёру" as S22

rectangle "SCR-23\nAI-ассистент (вопрос)" as S23
rectangle "SCR-24\nAI-ассистент (ответ)" as S24

rectangle "SCR-25\nПрофиль питомца" as S25

S01 --> S02 : нет профиля
S01 --> S08 : профиль есть
S02 --> S03
S03 --> S04
S04 --> S05
S05 --> S06
S06 --> S07
