@startuml
!include <C4/C4_Container>

Title Диаграмма контейнеров — PetFeed v1.0

' ── Акторы ──────────────────────────────────────────────────────
Person(owner, "Владелец питомца", "Пользователь Telegram")
Person(admin, "Администратор", "Управляет контентом и партнёрами")
Person(partner, "Партнёр (зоомагазин)", "Поставщик корма")

' ── Внешние системы ─────────────────────────────────────────────
System_Ext(telegram, "Telegram", "Платформа доставки сообщений")
System_Ext(claude_api, "DeepSeek API", "LLM для AI-ассистента по питанию животных")
System_Ext(partner_shop, "Системы зоомагазинов", "Каталог и приём заказов")

' ── Система PetFeed ──────────────────────────────────────────────
System_Boundary(petfeed, "PetFeed") {

    Container(bot, "Telegram Bot", "Python / aiogram 3", "Обрабатывает команды пользователя, управляет диалогом и состоянием FSM")

    Container(api, "Backend API", "Python / FastAPI", "Бизнес-логика: рекомендации, профили питомцев, напоминания, интеграции")

    Container(scheduler, "Scheduler", "Python / APScheduler", "Отправляет напоминания о кормлении в указанное пользователем время")

    Container(admin_panel, "Admin Panel", "Python / FastAPI + Jinja2", "Управление базой знаний о питании, партнёрами и пользователями")

    ContainerDb(main_db, "Main Database", "PostgreSQL", "Профили питомцев, пользователи, рационы, история заказов, расписания")

    ContainerDb(cache, "Cache", "Redis", "Кэш AI-ответов, состояния FSM бота, сессии пользователей")

}

' ── Связи: пользователь → бот ────────────────────────────────────
Rel(owner, telegram, "Пишет сообщения и нажимает кнопки")
Rel(telegram, bot, "Передаёт обновления", "Webhook / HTTPS")
Rel(bot, telegram, "Отправляет ответы и уведомления", "Bot API / HTTPS")

' ── Связи: бот → бэкенд ──────────────────────────────────────────
Rel(bot, api, "Запрашивает бизнес-логику", "REST / HTTP")
Rel(bot, cache, "Читает/пишет состояние FSM", "Redis protocol")

' ── Связи: бэкенд → данные ───────────────────────────────────────
Rel(api, main_db, "Читает и сохраняет данные", "SQL")
Rel(api, cache, "Кэширует ответы и сессии", "Redis protocol")

' ── Связи: бэкенд → внешние системы ─────────────────────────────
Rel(api, claude_api, "Отправляет запросы AI-ассистенту", "HTTPS / REST")
Rel(api, partner_shop, "Запрашивает каталог, передаёт переходы", "HTTPS / REST")
Rel(partner_shop, api, "Уведомляет об оформленных заказах", "Webhook / HTTPS")

' ── Связи: планировщик ───────────────────────────────────────────
Rel(scheduler, main_db, "Читает расписания кормлений", "SQL")
Rel(scheduler, bot, "Инициирует отправку напоминаний", "Internal call")

' ── Связи: администратор ─────────────────────────────────────────
Rel(admin, admin_panel, "Управляет данными через веб-интерфейс", "HTTPS")
Rel(admin_panel, main_db, "Читает и обновляет базу знаний", "SQL")

' ── Связи: партнёр ───────────────────────────────────────────────
Rel(partner, partner_shop, "Управляет каталогом товаров")

SHOW_LEGEND()
@enduml
