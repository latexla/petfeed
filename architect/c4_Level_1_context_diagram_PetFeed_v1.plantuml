@startuml
!include <C4/C4_Context>

Title Контекстная диаграмма — PetFeed v1.0

' ── Акторы ──────────────────────────────────────────────────────
Person(owner, "Владелец питомца", "Пользователь Telegram, хочет правильно кормить животное")
Person(partner, "Партнёр (зоомагазин)", "Поставщик корма, получает заказы через платформу")
Person(admin, "Администратор", "Управляет базой знаний и партнёрами")

' ── Центральная система ──────────────────────────────────────────
Enterprise_Boundary(petfeed_boundary, "PetFeed") {
    System(petfeed, "PetFeed", "Персональный нутрициолог для домашних животных. Рекомендации по питанию, напоминания о кормлении, заказ корма.")
}

' ── Внешние системы ─────────────────────────────────────────────
System_Ext(telegram, "Telegram", "Платформа для взаимодействия с пользователем через бота и Mini App")
System_Ext(claude_api, "DeepSeek API", "LLM для AI-ассистента и генерации персональных рекомендаций по питанию")
System_Ext(partner_shop, "Системы зоомагазинов", "Каталог товаров и приём заказов партнёров")

' ── Связи ───────────────────────────────────────────────────────
Rel(owner, telegram, "Отправляет сообщения и команды")
Rel(telegram, petfeed, "Передаёт запросы пользователя", "Webhook")
Rel(petfeed, telegram, "Отправляет ответы и уведомления", "Bot API")

Rel(petfeed, claude_api, "Запрашивает AI-ответы по питанию", "HTTPS / REST")
Rel(petfeed, partner_shop, "Запрашивает каталог и передаёт переходы", "HTTPS / REST")
Rel(partner_shop, petfeed, "Уведомляет об оформленных заказах", "Webhook")

Rel(partner, partner_shop, "Управляет каталогом товаров")
Rel(admin, petfeed, "Управляет базой знаний и партнёрами", "Web Admin Panel")

SHOW_LEGEND()
@enduml
