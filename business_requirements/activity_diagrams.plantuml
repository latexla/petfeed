@startuml UC001_CreatePetProfile
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam swimlaneWidth 200

title UC-001: Создание профиля питомца

|Пользователь|
start
:Запустить бота (/start);

|Система|
:Проверить наличие профиля пользователя;

if (Профиль существует?) then (да)
  :Показать главное меню;
  end
else (нет)
  :Показать приветствие и кнопку "Добавить питомца";
endif

|Пользователь|
:Нажать "Добавить питомца";

|Система|
:Отобразить список видов животных;

|Пользователь|
:Выбрать вид животного;

|Система|
:Запросить породу;

|Пользователь|
:Ввести породу или выбрать "Метис / Не знаю";

|Система|
:Запросить имя питомца;

|Пользователь|
:Ввести имя питомца;

|Система|
:Запросить возраст;

|Пользователь|
:Ввести возраст;

|Система|
if (Формат возраста корректен?) then (нет)
  :Показать сообщение об ошибке;
  :Повторно запросить возраст;
  stop
else (да)
  :Запросить вес питомца;
endif

|Пользователь|
:Ввести вес питомца;

|Система|
if (Формат веса корректен?) then (нет)
  :Показать сообщение об ошибке;
  :Повторно запросить вес;
  stop
else (да)
  :Сохранить профиль питомца в базу;
endif

if (Сохранение успешно?) then (нет)
  :Показать ошибку "Попробуйте позже";
  stop
else (да)
  :Показать сводку профиля;
  :Предложить перейти к рекомендациям;
endif

|Пользователь|
:Перейти к рекомендациям по питанию;
end

@enduml

' ─────────────────────────────────────────────────────────────────

@startuml UC002_GetNutritionRecommendation
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10

title UC-002: Получение рекомендаций по питанию

|Пользователь|
start
:Выбрать "Рацион питания" в меню;

|Система|
:Загрузить профиль активного питомца;
:Показать варианты цели (поддержание / похудение / набор / рост);

|Пользователь|
:Выбрать цель кормления;

|Система|
:Обратиться к базе знаний по параметрам питомца;

if (Данные для вида/породы найдены?) then (нет)
  :Вернуть базовые рекомендации для вида;
  :Добавить пометку "Уточните у ветеринара";
else (да)
  :Рассчитать суточную норму калорий;
  :Рассчитать объём и частоту порций;
endif

if (Вес питомца в критической зоне?) then (да)
  :Добавить предупреждение о весе;
  :Рекомендовать обратиться к ветеринару;
else (нет)
endif

:Сформировать рацион (разрешено / запрещено / расписание);
:Отобразить рацион пользователю;

fork
  :Предложить кнопку "Заказать корм";
fork again
  :Предложить кнопку "Настроить напоминания";
fork again
  :Предложить кнопку "Задать вопрос";
end fork

|Пользователь|
:Выбрать следующее действие;
end

@enduml

' ─────────────────────────────────────────────────────────────────

@startuml UC003_SetupReminders
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10

title UC-003: Настройка напоминаний о кормлении

|Пользователь|
start
:Нажать "Настроить напоминания";

|Система|
:Загрузить рекомендованное расписание кормлений;
:Показать предложенное расписание;

|Пользователь|
if (Принять предложенное расписание?) then (нет)
  :Выбрать "Настроить вручную";

  |Система|
  :Запросить время каждого кормления;

  |Пользователь|
  :Ввести время в формате HH:MM;

  |Система|
  if (Формат времени корректен?) then (нет)
    :Показать ошибку и повторить запрос;
    stop
  else (да)
  endif
else (да)
endif

|Система|
:Запросить часовой пояс пользователя;

|Пользователь|
:Указать часовой пояс;

|Система|
:Сохранить расписание напоминаний;
:Активировать уведомления через Telegram;

if (Telegram разрешает уведомления?) then (нет)
  :Показать инструкцию по разрешению уведомлений;
  stop
else (да)
  :Подтвердить активацию напоминаний;
  :Показать итоговое расписание;
endif

|Пользователь|
:Получить подтверждение настройки;
end

@enduml

' ─────────────────────────────────────────────────────────────────

@startuml UC004_OrderFood
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10

title UC-004: Заказ корма через партнёра

|Пользователь|
start
:Нажать "Заказать корм";

|Система|
:Загрузить рекомендованные корма из профиля;
:Запросить наличие и цены у партнёра;

if (Партнёр доступен?) then (нет)
  :Показать ошибку "Сервис временно недоступен";
  :Предложить альтернативного партнёра;
  stop
else (да)
endif

if (Рекомендованный корм есть в наличии?) then (нет)
  :Показать альтернативные позиции;
else (да)
  :Показать список рекомендованных кормов с ценами;
endif

|Пользователь|
:Выбрать корм;

|Система|
:Показать детали (состав, объём, цена, партнёр);

|Пользователь|
:Нажать "Перейти к заказу";

|Система|
:Сформировать реферальную ссылку;
:Зафиксировать реферальную сессию;
:Перенаправить на сайт партнёра;

|Партнёр|
:Принять и оформить заказ пользователя;

fork
  |Партнёр|
  :Отправить webhook об успешном заказе;

  |Система|
  :Зафиксировать заказ в истории;
  :Начислить комиссию;
fork again
  |Система|
  :Ожидать webhook 24 часа;
  if (Webhook получен?) then (нет)
    :Пометить заказ "Ожидает подтверждения";
  else (да)
  endif
end fork

|Пользователь|
:Получить подтверждение перехода к партнёру;
end

@enduml

' ─────────────────────────────────────────────────────────────────

@startuml UC007_AIAssistant
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10

title UC-007: Взаимодействие с AI-ассистентом

|Пользователь|
start
:Задать вопрос в свободной форме;

|Система|
:Проверить лимит запросов пользователя;

if (Лимит исчерпан?) then (да)
  :Показать предложение перейти на Premium;
  stop
else (нет)
endif

:Загрузить контекст профиля питомца;

if (Вопрос связан с питанием животных?) then (нет)
  :Вежливо перенаправить в контекст питомца;
  stop
else (да)
  :Сформировать запрос с контекстом питомца;
  :Отправить запрос в LLM API;
endif

if (LLM API доступен?) then (нет)
  :Поискать ответ в кэше похожих вопросов;
  if (Кэш найден?) then (да)
    :Вернуть кэшированный ответ с пометкой;
  else (нет)
    :Сообщить об ошибке "Попробуйте позже";
    stop
  endif
else (да)
  :Получить ответ от LLM;
endif

:Добавить дисклеймер "Не является ветеринарной консультацией";
:Показать ответ пользователю;

fork
  :Предложить "Обновить рацион";
fork again
  :Предложить "Проверить стоп-лист";
end fork

|Пользователь|
:Выбрать следующее действие;
end

@enduml
