@startuml UC001_CreatePetProfile
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 10
skinparam swimlaneWidth 200

title UC-001: Создание профиля питомца

|Пользователь|
start
:Запустить бота (/start);

|Система|
:Проверить наличие профиля пользователя;

if (Профиль существует?) then (да)
  :Показать главное меню;
  end
else (нет)
  :Показать приветствие и кнопку "Добавить питомца";
endif

|Пользователь|
:Нажать "Добавить питомца";

|Система|
:Отобразить список видов животных;

|Пользователь|
:Выбрать вид животного;

|Система|
:Запросить породу;

|Пользователь|
:Ввести породу или выбрать "Метис / Не знаю";

|Система|
:Запросить имя питомца;

|Пользователь|
:Ввести имя питомца;

|Система|
:Запросить возраст;

|Пользователь|
:Ввести возраст;

|Система|
if (Формат возраста корректен?) then (нет)
  :Показать сообщение об ошибке;
  :Повторно запросить возраст;
  stop
else (да)
  :Запросить вес питомца;
endif

|Пользователь|
:Ввести вес питомца;

|Система|
if (Формат веса корректен?) then (нет)
  :Показать сообщение об ошибке;
  :Повторно запросить вес;
  stop
else (да)
  :Сохранить профиль питомца в базу;
endif

if (Сохранение успешно?) then (нет)
  :Показать ошибку "Попробуйте позже";
  stop
else (да)
  :Показать сводку профиля;
  :Предложить перейти к рекомендациям;
endif

|Пользователь|
:Перейти к рекомендациям по питанию;
end

@enduml
